# Copy to .env and fill in Shopify values from `shopify app env` or Partner Dashboard.

# Local SQLite (default) lives at prisma/dev.sqlite. Leave DATABASE_URL unset — especially if
# your project path has spaces; relative file URLs can break SQLite on Windows.

# Only if you intentionally run Postgres locally (docker compose):
# USE_LOCAL_POSTGRES=1
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ewebworld"

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_customers,read_orders,write_app_proxy,write_metaobject_definitions,write_metaobjects,write_products
SHOPIFY_APP_URL=https://YOUR-HOST.example.com

# Optional
# SHOP_CUSTOM_DOMAIN=
