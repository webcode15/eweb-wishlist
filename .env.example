# Copy to .env and fill in values from `shopify app env` or Partner Dashboard.

# PostgreSQL (required for production; local default matches docker-compose.yml).
# Local: docker compose up -d
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/ewebworld?schema=public

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SCOPES=read_customers,read_orders,read_products,write_app_proxy,write_metaobject_definitions,write_metaobjects,write_products
SHOPIFY_APP_URL=https://YOUR-HOST.example.com

# Optional
# SHOP_CUSTOM_DOMAIN=
