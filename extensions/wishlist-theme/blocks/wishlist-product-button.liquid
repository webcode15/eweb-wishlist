{% if block.settings.enable_button %}
  {{ 'wishlist.css' | asset_url | stylesheet_tag }}
  <div
    class="eww-wishlist-product-block"
    data-shop-domain="{{ shop.permanent_domain }}"
    data-wishlist-handle="{{ product.handle }}"
    data-button-label="{{ block.settings.button_label | escape }}"
  >
    <button class="eww-wishlist-btn" type="button">
      {{ block.settings.button_label }}
    </button>
  </div>
  <script src="{{ 'wishlist.js' | asset_url }}" defer="defer"></script>
{% endif %}

{% schema %}
{
  "name": "Wishlist product button",
  "target": "section",
  "templates": ["product"],
  "settings": [
    {
      "type": "checkbox",
      "id": "enable_button",
      "label": "Enable product wishlist button",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Add to wishlist"
    }
  ]
}
{% endschema %}
